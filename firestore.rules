rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }
    
    // Lock down user collections (profile, expenses, notifications, settings)
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /expenses/{expenseId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /settings/{settingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /budgets/{budgetId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Lock down statement downloads requests
    match /statement_requests/{requestId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }
    

    // Lock down support cases (raised by FAQ panel)
    match /support_cases/{caseId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /broadcast_history/{broadcastId} {
      allow read, write: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }
  }
}
